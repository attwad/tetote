{
  "name": "tetote",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "build:css": "npx tailwindcss -i ./assets/css/input.css -o ./static/css/styles.css",
    "watch:css": "npx tailwindcss -i ./assets/css/input.css -o ./static/css/styles.css --watch",
    "build:js": "esbuild assets/js/main.js assets/js/product-detail.js assets/js/home.js --bundle --minify --outdir=static/js/bundles --format=esm --splitting",
    "watch:js": "esbuild assets/js/main.js assets/js/product-detail.js assets/js/home.js --bundle --sourcemap --outdir=static/js/bundles --format=esm --splitting --watch",
    "build": "npm run build:css && npm run build:js",
    "postinstall": "playwright install chromium"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@splidejs/splide": "^4.1.4",
    "photoswipe": "^5.4.4"
  }
}
